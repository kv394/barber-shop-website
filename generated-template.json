{
  "htmlCode": "<nav class=\"fixed top-0 w-full z-50 bg-zinc-950/80 backdrop-blur-xl shadow-sm border-b border-zinc-800\">\n<div class=\"flex justify-between items-center px-4 py-4 md:px-8 max-w-screen-2xl mx-auto\">\n<div class=\"text-2xl font-bold font-headline text-emerald-400 tracking-tighter\">\n{{shop.name}}\n</div>\n<!-- Desktop Navigation -->\n<div class=\"hidden md:flex items-center gap-8\">\n<a class=\"text-zinc-300 hover:text-emerald-400 transition-colors font-body text-sm tracking-wide uppercase\" href=\"#about\">{{aboutUsTitle}}</a>\n<a class=\"text-zinc-300 hover:text-emerald-400 transition-colors font-body text-sm tracking-wide uppercase\" href=\"#services\">{{servicesTitle}}</a>\n<a class=\"text-zinc-300 hover:text-emerald-400 transition-colors font-body text-sm tracking-wide uppercase\" href=\"#staff\">{{staffTitle}}</a>\n<a class=\"text-zinc-300 hover:text-emerald-400 transition-colors font-body text-sm tracking-wide uppercase\" href=\"#reviews\">{{reviewsTitle}}</a>\n<a class=\"text-zinc-300 hover:text-emerald-400 transition-colors font-body text-sm tracking-wide uppercase\" href=\"#gallery\">{{galleryTitle}}</a>\n</div>\n<div class=\"flex items-center gap-4\">\n<button class=\"bg-emerald-600 text-zinc-950 px-6 py-2 rounded-lg font-medium hover:opacity-80 transition-all duration-300\">\n                    Book Now\n                </button>\n<button class=\"text-emerald-400 hover:text-emerald-300 transition-colors\">\n<span class=\"material-symbols-outlined text-3xl\">account_circle</span>\n</button>\n<button class=\"md:hidden text-emerald-400\">\n<span class=\"material-symbols-outlined\">menu</span>\n</button>\n</div>\n</div>\n</nav>\n<main class=\"pt-24 bg-zinc-950 text-zinc-100\">\n<!-- Hero Section -->\n<section class=\"relative min-h-[80vh] flex items-center px-4 md:px-8 overflow-hidden\" id=\"home\">\n<div class=\"absolute inset-0 z-0 opacity-20\">\n<img alt=\"Barbershop interior with neon lights\" class=\"w-full h-full object-cover\" src=\"https://images.unsplash.com/photo-1547466189-9a116892a08c?auto=format&fit=crop&q=80&w=1974\"/>\n<div class=\"absolute inset-0 bg-gradient-to-t from-zinc-950 via-zinc-950/70 to-transparent\"></div>\n</div>\n<div class=\"max-w-7xl mx-auto w-full grid grid-cols-1 md:grid-cols-12 gap-8 items-center relative z-10 py-16\">\n<div class=\"md:col-span-7\">\n<span class=\"font-label text-emerald-400 tracking-[0.2em] uppercase text-sm mb-4 block\">{{shop.name}}</span>\n<h1 class=\"text-5xl md:text-7xl font-headline text-zinc-50 leading-[1.1] mb-6 tracking-tight drop-shadow-lg\">\n                        Future Cuts, <br/> <span class=\"italic text-emerald-400\">Heritage Style</span>\n</h1>\n<p class=\"text-lg text-zinc-300 font-body max-w-lg mb-8 leading-relaxed\">\n{{shop.description}}\n</p>\n<div class=\"flex items-center gap-4\">\n<button class=\"bg-emerald-600 text-zinc-950 px-8 py-4 rounded-lg shadow-lg shadow-emerald-500/20 hover:shadow-xl hover:shadow-emerald-500/30 transition-all font-semibold\">\n                            Book Your Style\n                        </button>\n<a class=\"text-emerald-400 font-semibold flex items-center gap-2 group px-4 py-4\" href=\"#services\">\n                            Explore Services\n                            <span class=\"material-symbols-outlined group-hover:translate-x-1 transition-transform\">arrow_forward</span>\n</a>\n</div>\n</div>\n<div class=\"md:col-span-5 relative h-[400px] md:h-[550px] flex items-center justify-center p-4\">\n<div class=\"absolute inset-0 bg-zinc-900 rounded-3xl overflow-hidden transform rotate-2 translate-x-4 translate-y-4 shadow-xl shadow-emerald-500/10\"></div>\n<img alt=\"Barber working on a client's hair\" class=\"relative w-full h-full object-cover rounded-3xl shadow-2xl shadow-emerald-500/20 transition-transform hover:scale-105 duration-700\" src=\"https://images.unsplash.com/photo-1582794541334-a14f24c0d164?auto=format&fit=crop&q=80&w=1974\"/>\n<div class=\"absolute bottom-8 -left-8 bg-zinc-900 p-4 rounded-2xl shadow-lg shadow-emerald-500/10 hidden lg:block border border-emerald-500/30\">\n<p class=\"font-headline italic text-emerald-400 text-xl\">\"Precision meets passion.\"</p>\n</div>\n</div>\n</div>\n</section>\n<!-- About Us Section -->\n<section class=\"py-24 px-4 md:px-8 bg-zinc-900\" id=\"about\">\n<div class=\"max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-12 items-center\">\n<div class=\"relative h-[400px] md:h-[500px]\">\n<img alt=\"Barber giving a haircut\" class=\"w-full h-full object-cover rounded-3xl shadow-xl shadow-emerald-500/10\" src=\"https://images.unsplash.com/photo-1579541579308-4183d2526541?auto=format&fit=crop&q=80&w=1974\"/>\n<div class=\"absolute bottom-8 right-8 bg-zinc-950 p-6 rounded-2xl shadow-xl shadow-emerald-500/10 border border-emerald-500/30 text-center\">\n<p class=\"font-headline italic text-emerald-400 text-2xl\">\"More than just a cut.\"</p>\n</div>\n</div>\n<div>\n<span class=\"font-label text-emerald-400 tracking-widest uppercase text-sm mb-2 block\">Our Story</span>\n<h2 class=\"text-4xl md:text-5xl font-headline text-zinc-50 mb-6\">{{aboutUsTitle}}</h2>\n<p class=\"font-body text-zinc-300 text-lg leading-relaxed mb-6\">{{aboutUsDescription}}</p>\n<p class=\"font-body text-zinc-400 leading-relaxed\">{{aboutUs}}</p>\n</div>\n</div>\n</section>\n<!-- Services Section -->\n<section class=\"py-24 px-4 md:px-8 bg-zinc-950\" id=\"services\">\n<div class=\"max-w-7xl mx-auto\">\n<div class=\"text-center mb-16\">\n<h2 class=\"text-4xl md:text-5xl font-headline text-zinc-50 mb-4\">{{servicesTitle}}</h2>\n<div class=\"w-24 h-px bg-emerald-400 mx-auto mb-6\"></div>\n<p class=\"font-body text-zinc-300 max-w-xl mx-auto\">{{servicesDescription}}</p>\n</div>\n<form>\n<div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-12\">\n{{#each shop.services}}\n<div class=\"group bg-zinc-900 p-8 rounded-2xl transition-all hover:translate-y-[-8px] hover:shadow-xl hover:shadow-emerald-500/10 border border-zinc-800 hover:border-emerald-500/50 relative overflow-hidden\">\n<input type=\"checkbox\" name=\"selectedServices\" value=\"{{this.id}}\" id=\"service-{{this.id}}\" class=\"absolute top-4 right-4 h-6 w-6 text-emerald-500 bg-zinc-800 border-zinc-700 rounded focus:ring-emerald-500 checked:bg-emerald-500 checked:border-emerald-500\"/>\n<label for=\"service-{{this.id}}\" class=\"block cursor-pointer\">\n<div class=\"w-14 h-14 bg-emerald-600/20 rounded-full flex items-center justify-center mb-6 text-emerald-400 group-hover:bg-emerald-600/30 transition-colors\">\n<span class=\"material-symbols-outlined text-3xl\">content_cut</span>\n</div>\n<h3 class=\"text-2xl font-headline text-zinc-50 mb-3\">{{this.name}}</h3>\n<p class=\"text-zinc-400 mb-6 leading-relaxed\">{{this.description}}</p>\n<div class=\"flex justify-between items-center text-zinc-300\">\n<span class=\"text-xl font-bold text-emerald-400\">${{this.price}}</span>\n<span class=\"text-zinc-500\">{{this.duration}} mins</span>\n</div>\n</label>\n</div>\n{{/each}}\n</div>\n<div class=\"text-center\">\n<button type=\"submit\" class=\"bg-emerald-600 text-zinc-950 px-10 py-4 rounded-lg shadow-lg shadow-emerald-500/20 hover:shadow-xl hover:shadow-emerald-500/30 transition-all font-semibold\">\n                        Book Selected\n                    </button>\n</div>\n</form>\n</div>\n</section>\n<!-- Staff Section -->\n<section class=\"py-24 px-4 md:px-8 bg-zinc-900\" id=\"staff\">\n<div class=\"max-w-7xl mx-auto\">\n<div class=\"text-center mb-16\">\n<h2 class=\"text-4xl md:text-5xl font-headline text-zinc-50 mb-4\">{{staffTitle}}</h2>\n<div class=\"w-24 h-px bg-emerald-400 mx-auto mb-6\"></div>\n<p class=\"font-body text-zinc-300 max-w-xl mx-auto\">{{staffDescription}}</p>\n</div>\n<div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8\">\n{{#each shop.users}}\n<div class=\"staff-card-example bg-zinc-950 p-8 rounded-2xl text-center shadow-lg shadow-emerald-500/10 border border-zinc-800\">\n<img class=\"w-32 h-32 rounded-full object-cover mx-auto mb-6 border-4 border-emerald-600/50 shadow-md\" src=\"https://i.pravatar.cc/150?img={{@index}}\" alt=\"{{this.name}}\"/>\n<h3 class=\"text-2xl font-headline text-zinc-50 mb-2\">{{this.name}}</h3>\n<p class=\"text-emerald-400 uppercase tracking-wide text-sm\">{{this.role}}</p>\n<p class=\"text-zinc-400 mt-4 text-sm\">Specializing in modern cuts and classic shaves, {{this.name}} brings years of experience and a keen eye for detail to every client.</p>\n</div>\n{{/each}}\n</div>\n</div>\n</section>\n<!-- Customer Reviews Section -->\n<section class=\"py-24 px-4 md:px-8 bg-zinc-950 overflow-hidden relative\" id=\"reviews\">\n<div class=\"absolute top-0 right-0 w-64 h-64 bg-emerald-600/10 rounded-full blur-[100px] -translate-y-1/2 translate-x-1/2\"></div>\n<div class=\"max-w-7xl mx-auto\">\n<div class=\"text-center mb-16\">\n<h2 class=\"text-4xl md:text-5xl font-headline text-zinc-50 mb-4\">{{reviewsTitle}}</h2>\n<div class=\"w-24 h-px bg-emerald-400 mx-auto mb-6\"></div>\n<p class=\"font-body text-zinc-300 max-w-xl mx-auto\">{{reviewsDescription}}</p>\n</div>\n<div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8\">\n{{#each shop.reviews}}\n<div class=\"review-card-example bg-zinc-900 p-8 rounded-2xl shadow-lg shadow-emerald-500/10 border border-zinc-800\">\n<div class=\"flex items-center mb-4\">\n{{#for 1 5}}\n<span class=\"material-symbols-outlined text-emerald-400 text-xl {{#if (gt this ../this.rating)}}opacity-30{{/if}}\">star</span>\n{{/for}}\n</div>\n<p class=\"font-body text-lg italic text-zinc-200 mb-6 leading-relaxed\">\n                                \"{{this.comment}}\"\n                            </p>\n<div class=\"flex items-center gap-4\">\n<div class=\"w-12 h-12 rounded-full bg-zinc-800 flex items-center justify-center text-emerald-400 text-xl font-bold\">{{this.user.name.[0]}}</div>\n<div>\n<p class=\"font-bold text-zinc-50\">{{this.user.name}}</p>\n<p class=\"text-xs text-zinc-400 uppercase tracking-widest\">Client</p>\n</div>\n</div>\n</div>\n{{/each}}\n</div>\n</div>\n</section>\n<!-- Gallery Section -->\n<section class=\"py-24 px-4 md:px-8 bg-zinc-900\" id=\"gallery\">\n<div class=\"max-w-7xl mx-auto\">\n<div class=\"flex flex-col md:flex-row justify-between items-start md:items-end mb-12 gap-6\">\n<div>\n<span class=\"font-label text-emerald-400 tracking-widest uppercase text-sm mb-2 block\">Our Craft</span>\n<h2 class=\"text-4xl md:text-5xl font-headline text-zinc-50\">{{galleryTitle}}</h2>\n<p class=\"font-body text-zinc-300 max-w-md mt-2\">{{gallerySubtitle}}</p>\n</div>\n<button class=\"text-zinc-400 hover:text-emerald-400 transition-colors flex items-center gap-2 border-b border-zinc-700 pb-1\">\n                        View All Creations\n                    </button>\n</div>\n<div class=\"grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6 auto-rows-[200px]\">\n{{#each shop.portfolioImages}}\n<div class=\"gallery-item-example col-span-{{#if (eq @index 0)}}2{{else if (eq @index 3)}}1{{else}}1{{/if}} row-span-{{#if (eq @index 0)}}2{{else if (eq @index 2)}}2{{else}}1{{/if}} rounded-2xl overflow-hidden relative group shadow-lg shadow-emerald-500/10\">\n<img alt=\"{{this.caption}}\" class=\"w-full h-full object-cover transition-transform duration-700 group-hover:scale-110\" src=\"{{this.imageUrl}}\"/>\n<div class=\"absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-6\">\n<p class=\"text-white font-headline text-lg\">{{this.caption}}</p>\n</div>\n</div>\n{{/each}}\n</div>\n</div>\n</section>\n<!-- Contact Section -->\n<section class=\"py-24 px-4 md:px-8 bg-zinc-950\" id=\"contact\">\n<div class=\"max-w-7xl mx-auto\">\n<div class=\"grid grid-cols-1 md:grid-cols-2 gap-16\">\n<div>\n<h2 class=\"text-4xl md:text-5xl font-headline text-zinc-50 mb-12\">{{contactTitle}}</h2>\n<div class=\"space-y-10\">\n<div class=\"flex gap-6\">\n<span class=\"material-symbols-outlined text-emerald-400 text-3xl\">location_on</span>\n<div>\n<h4 class=\"font-bold text-xl mb-2 text-zinc-50\">Our Location</h4>\n<p class=\"text-zinc-300\">{{contactAddress}}</p>\n</div>\n</div>\n<div class=\"flex gap-6\">\n<span class=\"material-symbols-outlined text-emerald-400 text-3xl\">schedule</span>\n<div>\n<h4 class=\"font-bold text-xl mb-2 text-zinc-50\">Operating Hours</h4>\n<div class=\"grid grid-cols-2 gap-x-8 text-zinc-300\">\n<span>Monday – Friday</span>\n<span>{{hoursMondayFriday}}</span>\n<span>Saturday</span>\n<span>{{hoursSaturday}}</span>\n<span>Sunday</span>\n<span>{{hoursSunday}}</span>\n</div>\n</div>\n</div>\n<div class=\"flex gap-6\">\n<span class=\"material-symbols-outlined text-emerald-400 text-3xl\">call</span>\n<div>\n<h4 class=\"font-bold text-xl mb-2 text-zinc-50\">Contact Details</h4>\n<p class=\"text-zinc-300\">{{contactPhone}}<br/>{{contactEmail}}</p>\n</div>\n</div>\n</div>\n</div>\n<div class=\"h-[500px] bg-zinc-900 rounded-3xl overflow-hidden relative shadow-xl shadow-emerald-500/10\">\n<div class=\"absolute inset-0 opacity-40 grayscale contrast-125\">\n<img alt=\"Map View of Barbershop location\" class=\"w-full h-full object-cover\" src=\"https://images.unsplash.com/photo-1549429188-75b9f931c8e8?auto=format&fit=crop&q=80&w=1974\"/>\n</div>\n<div class=\"absolute inset-0 flex items-center justify-center\">\n<div class=\"bg-zinc-950 p-8 rounded-2xl shadow-xl shadow-emerald-500/20 border border-emerald-500/30 text-center max-w-xs\">\n<div class=\"w-12 h-12 bg-emerald-600 rounded-full mx-auto mb-4 flex items-center justify-center text-zinc-950\">\n<span class=\"material-symbols-outlined\">pin_drop</span>\n</div>\n<p class=\"font-headline text-xl text-zinc-50\">{{shop.name}}</p>\n<p class=\"text-sm text-zinc-400 mb-4\">Located at {{contactAddress}}.</p>\n<button class=\"text-emerald-400 font-bold text-sm tracking-widest uppercase\">Get Directions</button>\n</div>\n</div>\n</div>\n</div>\n</div>\n</section>\n</main>\n<!-- Footer -->\n<footer class=\"w-full rounded-t-3xl mt-20 bg-zinc-900 border-t border-zinc-800\">\n<div class=\"grid grid-cols-1 md:grid-cols-3 gap-12 px-8 py-16 max-w-7xl mx-auto\">\n<div class=\"space-y-6\">\n<div class=\"text-xl font-headline text-emerald-400\">{{shop.name}}</div>\n<p class=\"text-zinc-400 font-body text-sm leading-relaxed\">\n{{shop.description}}\n</p>\n</div>\n<div class=\"grid grid-cols-2 gap-4\">\n<div class=\"space-y-4\">\n<a class=\"block text-zinc-400 hover:text-emerald-400 transition-colors font-body text-sm tracking-wide uppercase\" href=\"#\">Privacy Policy</a>\n<a class=\"block text-zinc-400 hover:text-emerald-400 transition-colors font-body text-sm tracking-wide uppercase\" href=\"#\">Terms of Service</a>\n<a class=\"block text-zinc-400 hover:text-emerald-400 transition-colors font-body text-sm tracking-wide uppercase\" href=\"#\">Careers</a>\n</div>\n<div class=\"space-y-4\">\n<a class=\"block text-zinc-400 hover:text-emerald-400 transition-colors font-body text-sm tracking-wide uppercase\" href=\"#about\">About Us</a>\n<a class=\"block text-zinc-400 hover:text-emerald-400 transition-colors font-body text-sm tracking-wide uppercase\" href=\"#services\">Services</a>\n<a class=\"block text-zinc-400 hover:text-emerald-400 transition-colors font-body text-sm tracking-wide uppercase\" href=\"#contact\">Contact</a>\n</div>\n</div>\n</div>\n<div class=\"text-center py-8 border-t border-zinc-800 text-zinc-500 text-sm\">\n        © {{shop.name}} 2023. All rights reserved.\n    </div>\n</footer>",
  "cssCode": "@import url('https://fonts.googleapis.com/css2?family=Noto+Serif:ital,wght@0,400;0,700;1,400&family=Manrope:wght@300;400;500;600;700&display=swap');\n@import url('https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap');\n\nbody { font-family: 'Manrope', sans-serif; }\nh1, h2, h3, .font-headline { font-family: 'Noto Serif', serif; }\n\n.material-symbols-outlined {\n    font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;\n}\n"
}