# =============================================================================
# KutzApp Environment Variables
# =============================================================================
# Copy this file to `.env` and fill in your actual values.
# NEVER commit the real `.env` file to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Database Configuration
# ---------------------------------------------------------------------------

# PostgreSQL connection string (pooled connection for general use)
POSTGRES_URL=postgresql://user:password@host:6543/dbname

# PostgreSQL connection string (non-pooling, for migrations and schema changes)
POSTGRES_URL_NON_POOLING=postgresql://user:password@host:5432/dbname

# Primary database URL used by Prisma / application
DATABASE_URL=postgresql://user:password@host:6543/dbname

# ---------------------------------------------------------------------------
# Application Configuration
# ---------------------------------------------------------------------------

# Comma-separated list of allowed root domains (include ports for local dev)
NEXT_PUBLIC_ROOT_DOMAIN=localhost:3000

# ---------------------------------------------------------------------------
# Supabase Configuration
# ---------------------------------------------------------------------------

# Your Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anonymous (public) API key — safe to expose client-side
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Cloudflare Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ---------------------------------------------------------------------------
# Vercel Log Monitoring
# ---------------------------------------------------------------------------

# Vercel API token for runtime log monitoring (generate at vercel.com/account/tokens)
VERCEL_API_TOKEN=your-vercel-api-token

# Vercel project ID (found in .vercel/repo.json or project settings)
VERCEL_PROJECT_ID=prj_KUmKRUP1RGviLrGQJ9SmSD8cO2nz

# ---------------------------------------------------------------------------
# Demo / Seed Data
# ---------------------------------------------------------------------------

# The CUID of the demo shop used for slug aliases like "missouri-city" / "sugarland"
DEMO_SHOP_ID=
