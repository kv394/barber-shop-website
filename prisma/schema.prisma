generator client {
  provider        = "prisma-client-js"
  engineType      = "library"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
}

model Shop {
  id                  String               @id @default(cuid())
  name                String
  description         String?
  template            String               @default("modern")
  customization       Json?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  timezone            String               @default("America/New_York")
  depositAmount       Float                @default(0)
  depositRequired     Boolean              @default(false)
  stripeAccountId     String?
  customDomain        String?              @unique
  subdomain           String?              @unique
  companyName         String?
  aiTokens            Int                  @default(0)
  slogan              String?
  appointments        Appointment[]
  campaigns           Campaign[]
  clientFormulas      ClientFormula[]
  clientHistoryImages ClientHistoryImage[]
  commissionRules     CommissionRule[]
  dynamicTemplates    DynamicTemplate[]
  expenses            Expense[]
  formTemplates       FormTemplate[]
  giftCards           GiftCard[]
  leaves              Leave[]
  loyaltyAccounts     LoyaltyAccount[]
  loyaltyProgram      LoyaltyProgram?
  membershipTiers     MembershipTier[]
  messages            Message[]
  notifications       Notification[]
  portfolioImages     PortfolioImage[]
  products            Product[]
  referrals           Referral[]
  resources           Resource[]
  reviews             Review[]
  services            Service[]
  serviceAddons       ServiceAddon[]
  shopAccesses        ShopAccess[]
  blackoutDates       ShopBlackoutDate[]
  usageReports        ShopUsageReport[]
  timeLogs            TimeLog[]
  users               User[]
  userMemberships     UserMembership[]
  waitlist            Waitlist[]
  purchaseOrders      PurchaseOrder[]
  boothRentPayments   BoothRentPayment[]

  @@index([createdAt])
}

model User {
  id                      String                  @id @default(cuid())
  email                   String                  @unique
  name                    String?
  role                    UserRole
  canManageInventory      Boolean                 @default(false)
  barcode                 String?                 @unique
  shopId                  String?
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  workingHours            Json?
  clientNotes             String?
  allergies               String?
  commissionRateProduct   Float?
  commissionRateService   Float?
  marketingConsent        Boolean                 @default(false)
  phone                   String?
  preferences             String?
  smsConsent              Boolean                 @default(false)
  birthday                DateTime?
  referralCode            String?                 @unique
  googleCalendarId        String?
  googleRefreshToken      String?
  imageUrl                String?
  recoveryTotpSecret      String?
  stripeCustomerId        String?
  stripePaymentMethodId   String?
  staffAppointments       Appointment[]           @relation("StaffAppointments")
  clientAppointments      Appointment[]           @relation("ClientAppointments")
  clientFormulas          ClientFormula[]         @relation("ClientFormulas")
  staffFormulas           ClientFormula[]         @relation("StaffFormulas")
  clientHistoryImages     ClientHistoryImage[]    @relation("ClientHistoryImages")
  commissionRules         CommissionRule[]        @relation("StaffCommissionRules")
  formSubmissions         FormSubmission[]
  leaves                  Leave[]
  loyaltyAccounts         LoyaltyAccount[]
  messages                Message[]
  notifications           Notification[]
  notificationPreferences NotificationPreference?
  portfolioImages         PortfolioImage[]        @relation("StaffPortfolio")
  referralsReceived       Referral[]              @relation("RefereeReferrals")
  referralsMade           Referral[]              @relation("ReferrerReferrals")
  reviews                 Review[]
  shopAccesses            ShopAccess[]
  timeLogs                TimeLog[]
  shop                    Shop?                   @relation(fields: [shopId], references: [id])
  memberships             UserMembership[]
  boothRentPayments       BoothRentPayment[]

  @@index([shopId, role])
  @@index([email])
}

model Product {
  id                 String              @id @default(cuid())
  name               String
  description        String?
  sku                String?
  barcode            String?             @unique
  price              Float
  cost               Float?
  taxRate            Float               @default(0)
  trackInventory     Boolean             @default(false)
  inventoryCount     Int                 @default(0)
  reorderPoint       Int                 @default(0)
  type               ProductType         @default(RETAIL)
  supplier           String?
  shopId             String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  isSellable         Boolean             @default(true)
  imageUrl           String?
  appointmentItems   AppointmentItem[]
  shop               Shop                @relation(fields: [shopId], references: [id])
  purchaseOrderItems PurchaseOrderItem[]

  @@index([shopId, type])
}

model Service {
  id                   String                       @id @default(cuid())
  name                 String
  description          String?
  price                Float
  duration             Int
  trackInventory       Boolean                      @default(false)
  inventoryCount       Int                          @default(0)
  type                 ServiceType                  @default(CUSTOMER)
  itemType             String?
  brand                String?
  barcode              String?                      @unique
  shopId               String
  createdAt            DateTime                     @default(now())
  updatedAt            DateTime                     @updatedAt
  taxRate              Float                        @default(0)
  bufferMinutes        Int                          @default(0)
  imageUrl             String?
  finishingTime        Int                          @default(0)
  processingTime       Int                          @default(0)
  isBookable           Boolean                      @default(true)
  appointments         Appointment[]
  appointmentItems     AppointmentItem[]
  commissionRules      CommissionRule[]
  resourceRequirements ServiceResourceRequirement[]
  shop                 Shop                         @relation(fields: [shopId], references: [id])
  addons               ServiceAddon[]               @relation("ServiceToAddons")

  @@index([shopId, type])
}

model ServiceAddon {
  id          String    @id @default(cuid())
  name        String
  price       Float
  durationMin Int       @default(0)
  shopId      String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  shop        Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  services    Service[] @relation("ServiceToAddons")

  @@index([shopId])
}

model Appointment {
  id                     String               @id @default(cuid())
  startTime              DateTime
  endTime                DateTime
  serviceId              String?
  userId                 String
  staffId                String
  shopId                 String
  status                 AppointmentStatus    @default(SCHEDULED)
  paymentId              String?              @unique
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  notes                  String?
  discount               Float                @default(0)
  paymentMethod          String?
  tipAmount              Float                @default(0)
  subtotal               Float                @default(0)
  taxAmount              Float                @default(0)
  totalAmount            Float                @default(0)
  depositAmount          Float                @default(0)
  depositPaymentIntentId String?
  isRecurringParent      Boolean              @default(false)
  recurrenceRule         String?
  recurringGroupId       String?
  refundAmount           Float                @default(0)
  refundedAt             DateTime?
  resourceId             String?
  addons                 Json?
  resource               Resource?            @relation(fields: [resourceId], references: [id])
  service                Service?             @relation(fields: [serviceId], references: [id])
  shop                   Shop                 @relation(fields: [shopId], references: [id])
  staff                  User                 @relation("StaffAppointments", fields: [staffId], references: [id])
  user                   User                 @relation("ClientAppointments", fields: [userId], references: [id])
  items                  AppointmentItem[]
  clientHistoryImages    ClientHistoryImage[]
  formSubmissions        FormSubmission[]
  payments               Payment[]
  review                 Review?

  @@index([shopId, startTime])
  @@index([shopId, status])
  @@index([staffId, startTime, endTime])
  @@index([userId])
  @@index([addons], type: Gin)
}

model AppointmentItem {
  id            String      @id @default(cuid())
  appointmentId String
  serviceId     String?
  productId     String?
  name          String
  price         Float
  quantity      Int         @default(1)
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  product       Product?    @relation(fields: [productId], references: [id])
  service       Service?    @relation(fields: [serviceId], references: [id])
}

model Payment {
  id            String        @id @default(cuid())
  appointmentId String
  amount        Float
  method        PaymentMethod
  status        PaymentStatus @default(COMPLETED)
  transactionId String?
  receiptUrl    String?
  createdAt     DateTime      @default(now())
  appointment   Appointment   @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
}

model CommissionRule {
  id        String         @id @default(cuid())
  shopId    String
  staffId   String?
  serviceId String?
  rateType  CommissionType @default(PERCENTAGE)
  rateValue Float
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  service   Service?       @relation(fields: [serviceId], references: [id])
  shop      Shop           @relation(fields: [shopId], references: [id])
  staff     User?          @relation("StaffCommissionRules", fields: [staffId], references: [id])
}

model Expense {
  id          String   @id @default(cuid())
  amount      Float
  category    String
  description String?
  date        DateTime @default(now())
  shopId      String
  createdAt   DateTime @default(now())
  shop        Shop     @relation(fields: [shopId], references: [id])

  @@index([shopId, date])
}

model Review {
  id            String       @id @default(cuid())
  rating        Int
  comment       String?
  appointmentId String?      @unique
  userId        String
  shopId        String
  createdAt     DateTime     @default(now())
  ownerResponse String?
  respondedAt   DateTime?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  shop          Shop         @relation(fields: [shopId], references: [id])
  user          User         @relation(fields: [userId], references: [id])

  @@index([shopId, createdAt])
}

model ShopBlackoutDate {
  id        String   @id @default(cuid())
  shopId    String
  date      DateTime
  reason    String?
  createdAt DateTime @default(now())
  shop      Shop     @relation(fields: [shopId], references: [id])

  @@unique([shopId, date])
  @@index([shopId])
}

model Waitlist {
  id          String   @id @default(cuid())
  clientName  String
  clientPhone String?
  partySize   Int      @default(1)
  serviceId   String?
  status      String   @default("WAITING")
  position    Int
  shopId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  staffId     String?
  shop        Shop     @relation(fields: [shopId], references: [id])

  @@index([shopId, createdAt])
}

model Leave {
  id        String   @id @default(cuid())
  date      DateTime @db.Date
  reason    String?
  userId    String
  shopId    String
  createdAt DateTime @default(now())
  endTime   DateTime
  startTime DateTime
  shop      Shop     @relation(fields: [shopId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@index([shopId, date])
  @@index([userId, date])
}

model TimeLog {
  id       String    @id @default(cuid())
  clockIn  DateTime  @default(now())
  clockOut DateTime?
  userId   String
  shopId   String
  shop     Shop      @relation(fields: [shopId], references: [id])
  user     User      @relation(fields: [userId], references: [id])

  @@index([shopId])
  @@index([userId, clockIn])
}

model SystemLog {
  id         String   @id @default(cuid())
  level      String   @default("ERROR")
  message    String
  stack      String?
  path       String?
  shopId     String?
  userId     String?
  metadata   Json?
  isResolved Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([shopId])
  @@index([level])
  @@index([createdAt])
}

model LoyaltyProgram {
  id              String   @id @default(cuid())
  shopId          String   @unique
  pointsPerDollar Float    @default(1)
  pointsPerVisit  Int      @default(10)
  redeemThreshold Int      @default(100)
  redeemValue     Float    @default(5)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  pointExpiryDays Int      @default(0)
  tiers           Json?
  shop            Shop     @relation(fields: [shopId], references: [id])
}

model LoyaltyAccount {
  id             String               @id @default(cuid())
  userId         String
  shopId         String
  pointsBalance  Int                  @default(0)
  totalEarned    Int                  @default(0)
  totalRedeemed  Int                  @default(0)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  currentTier    String               @default("Bronze")
  lifetimePoints Int                  @default(0)
  shop           Shop                 @relation(fields: [shopId], references: [id])
  user           User                 @relation(fields: [userId], references: [id])
  transactions   LoyaltyTransaction[]

  @@unique([userId, shopId])
  @@index([shopId])
}

model LoyaltyTransaction {
  id               String         @id @default(cuid())
  loyaltyAccountId String
  points           Int
  type             String
  description      String?
  appointmentId    String?
  createdAt        DateTime       @default(now())
  expiresAt        DateTime?
  loyaltyAccount   LoyaltyAccount @relation(fields: [loyaltyAccountId], references: [id], onDelete: Cascade)

  @@index([loyaltyAccountId])
  @@index([expiresAt])
}

model Referral {
  id                   String   @id @default(cuid())
  shopId               String
  referrerId           String
  refereeId            String
  status               String   @default("PENDING")
  referrerRewardPoints Int      @default(50)
  refereeRewardPoints  Int      @default(25)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  referee              User     @relation("RefereeReferrals", fields: [refereeId], references: [id])
  referrer             User     @relation("ReferrerReferrals", fields: [referrerId], references: [id])
  shop                 Shop     @relation(fields: [shopId], references: [id])

  @@unique([shopId, refereeId])
  @@index([shopId])
  @@index([referrerId])
}

model Campaign {
  id             String    @id @default(cuid())
  shopId         String
  name           String
  message        String
  type           String    @default("PROMO")
  channel        String    @default("EMAIL")
  status         String    @default("DRAFT")
  targetSegment  String    @default("ALL")
  scheduledAt    DateTime?
  sentAt         DateTime?
  recipientCount Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  shop           Shop      @relation(fields: [shopId], references: [id])

  @@index([shopId])
  @@index([status])
}

model Notification {
  id          String    @id @default(cuid())
  shopId      String
  userId      String
  type        String
  channel     String    @default("EMAIL")
  title       String
  message     String
  status      String    @default("PENDING")
  scheduledAt DateTime?
  sentAt      DateTime?
  createdAt   DateTime  @default(now())
  maxRetries  Int       @default(3)
  retryCount  Int       @default(0)
  shop        Shop      @relation(fields: [shopId], references: [id])
  user        User      @relation(fields: [userId], references: [id])

  @@index([shopId])
  @@index([userId])
  @@index([status, scheduledAt])
  @@index([status, retryCount])
}

model NotificationPreference {
  id                   String   @id @default(cuid())
  userId               String   @unique
  appointmentReminders Boolean  @default(true)
  reviewRequests       Boolean  @default(true)
  promotions           Boolean  @default(true)
  birthdayMessages     Boolean  @default(true)
  loyaltyUpdates       Boolean  @default(true)
  preferredChannel     String   @default("EMAIL")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id])
}

model GiftCard {
  id             String         @id @default(cuid())
  code           String         @unique
  shopId         String
  purchaserEmail String?
  recipientEmail String?
  recipientName  String?
  initialBalance Float
  currentBalance Float
  expiresAt      DateTime?
  status         GiftCardStatus @default(ACTIVE)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  shop           Shop           @relation(fields: [shopId], references: [id])

  @@index([shopId])
  @@index([code])
}

model DynamicTemplate {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  prompt      String?
  htmlCode    String
  cssCode     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  shopId      String?
  variables   Json?
  shop        Shop?    @relation(fields: [shopId], references: [id])
}

model Resource {
  id           String        @id @default(cuid())
  name         String
  type         String
  shopId       String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]
  shop         Shop          @relation(fields: [shopId], references: [id])

  @@index([shopId])
}

model FormTemplate {
  id          String           @id @default(cuid())
  name        String
  content     String
  isRequired  Boolean          @default(false)
  shopId      String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  submissions FormSubmission[]
  shop        Shop             @relation(fields: [shopId], references: [id])

  @@index([shopId])
}

model FormSubmission {
  id             String       @id @default(cuid())
  appointmentId  String
  clientId       String
  formTemplateId String
  contentData    Json
  signatureUrl   String?
  submittedAt    DateTime     @default(now())
  appointment    Appointment  @relation(fields: [appointmentId], references: [id])
  client         User         @relation(fields: [clientId], references: [id])
  formTemplate   FormTemplate @relation(fields: [formTemplateId], references: [id])

  @@index([appointmentId])
  @@index([clientId])
}

model ClientFormula {
  id        String   @id @default(cuid())
  formula   String
  notes     String?
  date      DateTime @default(now())
  clientId  String
  staffId   String
  shopId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  client    User     @relation("ClientFormulas", fields: [clientId], references: [id])
  shop      Shop     @relation(fields: [shopId], references: [id])
  staff     User     @relation("StaffFormulas", fields: [staffId], references: [id])

  @@index([clientId])
  @@index([shopId])
}

model ClientHistoryImage {
  id            String       @id @default(cuid())
  imageUrl      String
  imageType     String       @default("AFTER")
  date          DateTime     @default(now())
  clientId      String
  appointmentId String?
  shopId        String
  createdAt     DateTime     @default(now())
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  client        User         @relation("ClientHistoryImages", fields: [clientId], references: [id])
  shop          Shop         @relation(fields: [shopId], references: [id])

  @@index([clientId])
  @@index([appointmentId])
}

model MembershipTier {
  id              String           @id @default(cuid())
  name            String
  description     String?
  price           Float
  interval        String           @default("MONTHLY")
  stripeProductId String?
  stripePriceId   String?
  shopId          String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  shop            Shop             @relation(fields: [shopId], references: [id])
  members         UserMembership[]

  @@index([shopId])
}

model UserMembership {
  id                   String         @id @default(cuid())
  status               String         @default("ACTIVE")
  stripeSubscriptionId String?
  currentPeriodEnd     DateTime?
  userId               String
  membershipTierId     String
  shopId               String
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  membershipTier       MembershipTier @relation(fields: [membershipTierId], references: [id])
  shop                 Shop           @relation(fields: [shopId], references: [id])
  user                 User           @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([shopId])
}

model PortfolioImage {
  id           String   @id @default(cuid())
  imageUrl     String
  caption      String?
  displayOrder Int      @default(0)
  staffId      String
  shopId       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  shop         Shop     @relation(fields: [shopId], references: [id])
  staff        User     @relation("StaffPortfolio", fields: [staffId], references: [id])

  @@index([staffId])
  @@index([shopId])
}

model ShopUsageReport {
  id                      String   @id @default(cuid())
  shopId                  String
  period                  DateTime
  userCount               Int
  appointmentCount        Int
  productCount            Int
  serviceCount            Int
  formSubmissionCount     Int
  portfolioImageCount     Int
  clientHistoryImageCount Int
  clientFormulaCount      Int
  reviewCount             Int
  estimatedStorageMB      Float
  suggestedMonthlyFeeUSD  Float
  pricingTierName         String
  createdAt               DateTime @default(now())
  shop                    Shop     @relation(fields: [shopId], references: [id])

  @@index([shopId, period])
}

model SaaSTier {
  id                 String   @id @default(cuid())
  name               String   @unique
  baseFeeUSD         Float
  maxAppointments    Int
  maxUsers           Int
  maxFormSubmissions Int
  storageLimitMB     Float    @default(500)
  overageFeePer100MB Float    @default(1)
  description        String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Message {
  id        String   @id @default(cuid())
  shopId    String
  senderId  String
  content   String
  createdAt DateTime @default(now())
  imageUrl  String?
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, createdAt])
}

model ShopAccess {
  id        String   @id @default(cuid())
  userId    String
  shopId    String
  role      UserRole
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, shopId])
  @@index([shopId])
}

enum ProductType {
  RETAIL
  BACKBAR
}

enum PaymentMethod {
  CASH
  CARD
  MOBILE
  GIFT_CARD
  OTHER
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum CommissionType {
  PERCENTAGE
  FLAT
}

enum UserRole {
  SITE_ADMIN
  SHOP_ADMIN
  STAFF
  CLIENT
  ATTENDANCE_KIOSK
}

enum ServiceType {
  CUSTOMER
  INTERNAL
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
  ACCEPTED
  WORK_COMPLETED
}

enum GiftCardStatus {
  ACTIVE
  REDEEMED
  EXPIRED
  CANCELLED
}

enum EmploymentType {
  W2
  CONTRACTOR
}

enum BoothRentInterval {
  WEEKLY
  MONTHLY
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  RECEIVED
  CANCELLED
}

model ServiceResourceRequirement {
  id           String  @id @default(cuid())
  serviceId    String
  resourceType String
  quantity     Int     @default(1)
  service      Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId])
}

model PurchaseOrder {
  id                   String              @id @default(cuid())
  shopId               String
  supplier             String
  status               PurchaseOrderStatus @default(DRAFT)
  totalAmount          Float               @default(0)
  orderDate            DateTime            @default(now())
  expectedDeliveryDate DateTime?
  receivedAt           DateTime?
  notes                String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  shop                 Shop                @relation(fields: [shopId], references: [id])
  items                PurchaseOrderItem[]

  @@index([shopId, status])
}

model PurchaseOrderItem {
  id               String        @id @default(cuid())
  purchaseOrderId  String
  productId        String
  quantity         Int
  receivedQuantity Int           @default(0)
  unitCost         Float
  purchaseOrder    PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product          Product       @relation(fields: [productId], references: [id])

  @@index([purchaseOrderId])
  @@index([productId])
}

model BoothRentPayment {
  id               String        @id @default(cuid())
  shopId           String
  userId           String
  amount           Float
  periodStart      DateTime
  periodEnd        DateTime
  status           PaymentStatus @default(PENDING)
  paidAt           DateTime?
  stripeTransferId String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  shop             Shop          @relation(fields: [shopId], references: [id])
  user             User          @relation(fields: [userId], references: [id])

  @@index([shopId])
  @@index([userId])
}
